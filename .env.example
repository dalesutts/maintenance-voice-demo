# Required
RETELL_API_KEY=your_retell_api_key
LLM_API_KEY=your_anthropic_api_key
RETELL_AGENT_ID=your_retell_agent_id

# Optional
PORT=8080

# SMS (optional — photo upload link)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Security
# Comma-separated allowlist of origins that may call /create-web-call and
# receive CORS headers. Defaults to localhost + the Render demo host.
ALLOWED_ORIGINS=http://localhost:8080,https://maintenance-voice-demo.onrender.com

# If set, /create-web-call requires the `X-Demo-Secret` header to match.
# Leave unset to allow any origin in ALLOWED_ORIGINS to start a call.
DEMO_SECRET=
